---
/**
 * About Page (about.astro → yoursite.com/about)
 *
 * A simple static page. Edit the HTML below to tell visitors about
 * yourself and your NFT collection.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="about-content">
    <h1>About</h1>
    <p>
      This gallery presents a curated selection of contemporary digital artworks,
      exploring themes of nature, memory, and the human form through the lens of
      modern painting traditions.
    </p>
    <p>
      Each work exists as a verified digital edition on the Ethereum blockchain.
      Acquisitions are facilitated through
      <a href="https://opensea.io" target="_blank" rel="noopener noreferrer">OpenSea</a>.
    </p>
    <p>
      For inquiries regarding the collection or the artist, please reach out
      through OpenSea's messaging system.
    </p>
  </div>
</BaseLayout>
