---
/**
 * BaseLayout
 *
 * The shared HTML shell used by every page. Contains:
 * - <head> with global styles and SEO meta tags
 * - Navigation bar
 * - Main content slot (where page content goes)
 * - Footer
 *
 * Every page wraps its content in this layout:
 *   <BaseLayout title="Page Title">
 *     ...page content...
 *   </BaseLayout>
 */
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead title={title} description={description} image={image} />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="nav-logo">The Silent Echo</a>
        <ul class="nav-links">
          <li><a href="/">Collection</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </nav>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        &copy; {new Date().getFullYear()} The Silent Echo Gallery. All Rights Reserved.
      </p>
    </footer>
  </body>
</html>
